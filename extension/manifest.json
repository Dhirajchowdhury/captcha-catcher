{
  "manifest_version": 3,
  "name": "Captcha Catcher",
  "version": "1.0",
  "description": "Automatically detects and solves CAPTCHAs on any webpage",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background/background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "utils/domHelper.js",
        "utils/imageCapture.js",
        "utils/detector.js",
        "strategies/mathCaptcha.js",
        "strategies/textCaptcha.js",
        "strategies/gridCaptcha.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  }
}